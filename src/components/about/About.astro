---
// src/components/about/About.astro

import { getLangFromUrl, useTranslations } from '../../i18n/utils';

// 1. Preparamos el traductor para el texto normal
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 2. Mantenemos las skills fijas (términos estándar del sector)
const skills = [
  "Cybersecurity Engineer Student",
  "IoT Pentester",
  "Hardware Hacker",
  "Reverse Engineer"
];

const aboutImage = "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=1000&auto=format&fit=crop";

// Función MEJORADA: Agrupa letras en palabras para que nunca se partan por la mitad
const splitIntoHackerLetters = (text: string) => {
  return text.split(' ').map(word => {
    const lettersSpans = word.split('').map(char => {
      return `<span class="hacker-skill-letter inline-block transition-colors duration-100" data-original="${char}">${char}</span>`;
    }).join('');
    return `<span class="inline-block whitespace-nowrap">${lettersSpans}</span>`;
  }).join(' '); 
};
---

<section id="about" class="w-full min-h-screen bg-black relative px-6 md:px-12 lg:px-20 pb-24 flex flex-col overflow-hidden">

  {/* 1. TEXTO 'ABOUT' GIGANTE */}
  <div class="w-full flex justify-center pt-20 lg:pt-28 z-0 pointer-events-none select-none">
    {/* Tamaños reducidos para que 'ABOUT' (5 letras) nunca supere el ancho de la pantalla */}
    <h2 class="text-[#131313] font-syncopate font-bold text-[22vw] sm:text-[20vw] md:text-[15vw] leading-none uppercase tracking-tighter">
      About
    </h2>
  </div>

  {/* 2. CONTENEDOR IMAGEN Y TEXTO */}
  <div class="relative z-10 w-full max-w-[90rem] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start mt-20 lg:mt-5">
    
    {/* COLUMNA IZQUIERDA: IMAGEN RECTANGULAR */}
    <div class="w-full">
      <div class="relative overflow-hidden border border-zinc-800 group interactable">
        <img 
          src={aboutImage} 
          alt="Joan Francesc - About Image" 
          class="w-full h-auto object-cover aspect-[4/3] md:aspect-video grayscale group-hover:grayscale-0 transition-all duration-700 ease-in-out scale-100 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black/30 group-hover:bg-transparent transition-colors duration-500"></div>
      </div>
    </div>

    {/* COLUMNA DERECHA: TEXTO DE PRESENTACIÓN */}
    <div class="w-full flex lg:justify-end">
      <div class="font-fira text-sm md:text-base text-gray-300 leading-relaxed tracking-wider interactable relative z-20 md:max-w-lg lg:max-w-none">
        <p class="mb-6">
          {t('about.p1')}
        </p>
        <p>
          {t('about.p2')}
        </p>
        
        <div class="mt-8 md:mt-12">
          <a href="mailto:tuemail@ejemplo.com" class="inline-flex items-center gap-2 text-white uppercase font-syncopate tracking-widest text-xs group hover:text-green-400 transition-colors">
            {t('about.contact')}
            <span class="text-green-500 group-hover:translate-x-2 transition-transform duration-300">-></span>
          </a>
        </div>
      </div>
    </div>

  </div>

  {/* 3. LISTA DE ROLES GIGANTE (CON EFECTO HACKER) */}
  <div class="w-full flex flex-col items-center justify-center gap-6 md:gap-8 relative z-10 select-none overflow-hidden mt-24 lg:mt-32 px-2 md:px-4">
    {skills.map((skill) => (
      <h3 
        class="skill-row text-zinc-800 text-center font-syncopate uppercase font-bold text-[8vw] sm:text-5xl md:text-6xl lg:text-[5vw] leading-[1.2] md:leading-none cursor-default interactable max-w-full"
        set:html={splitIntoHackerLetters(skill)}
      ></h3>
    ))}
  </div>

</section>

<script>
  const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*+<>{}[]";
  const skillLetters = document.querySelectorAll('.hacker-skill-letter');

  const calculateSkillWidths = () => {
    skillLetters.forEach((letter) => {
      const el = letter as HTMLElement;
      el.style.width = 'auto'; 
      const rect = el.getBoundingClientRect();
      el.style.width = `${rect.width}px`;
      el.style.textAlign = 'center';
    });
  };

  document.fonts.ready.then(calculateSkillWidths);

  let resizeTimerSkill: number;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimerSkill);
    resizeTimerSkill = window.setTimeout(calculateSkillWidths, 200);
  });

  const triggerHackerEffect = (el: HTMLElement) => {
    let iterations = 0;
    const original = el.dataset.original;
    
    if (!original || original === ' ') return;

    if (el.dataset.interval) {
      clearInterval(parseInt(el.dataset.interval));
    }

    el.classList.add('text-green-500');

    const interval = window.setInterval(() => {
      el.innerText = chars[Math.floor(Math.random() * chars.length)];
      iterations++;

      if (iterations >= 20) {
        clearInterval(interval);
        el.innerText = original;
        el.classList.remove('text-green-500');
      }
    }, 40);

    el.dataset.interval = interval.toString();
  };

  skillLetters.forEach((letter) => {
    letter.addEventListener('mouseleave', () => triggerHackerEffect(letter as HTMLElement));
  });

  let lastTouchedSkillLetter: Element | null = null;

  document.addEventListener('touchmove', (e) => {
    const touch = e.touches[0];
    const currentElement = document.elementFromPoint(touch.clientX, touch.clientY);

    if (
      lastTouchedSkillLetter && 
      lastTouchedSkillLetter.classList.contains('hacker-skill-letter') && 
      lastTouchedSkillLetter !== currentElement
    ) {
      triggerHackerEffect(lastTouchedSkillLetter as HTMLElement);
    }
    
    lastTouchedSkillLetter = currentElement;
  }, { passive: true });

  document.addEventListener('touchend', () => {
    if (lastTouchedSkillLetter && lastTouchedSkillLetter.classList.contains('hacker-skill-letter')) {
      triggerHackerEffect(lastTouchedSkillLetter as HTMLElement);
    }
    lastTouchedSkillLetter = null;
  });
</script>