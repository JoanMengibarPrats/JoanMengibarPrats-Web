---
import { getCollection } from 'astro:content';
// IMPORTANTE: Importamos nuestro nuevo y flamante BlogPost
import BlogPost from '../../layouts/BlogPost.astro';

// 1. Generamos una página estática por cada post en español
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Filtramos solo los de la carpeta "es/"
  const spanishPosts = posts.filter(post => post.slug.startsWith('es/'));
  
  return spanishPosts.map(post => {
    // Le quitamos el "es/" al slug para que la URL sea limpia
    const cleanSlug = post.slug.replace('es/', '');
    
    return {
      params: { slug: cleanSlug }, 
      props: { post },             
    };
  });
}

// 2. Extraemos el post correspondiente a la URL actual
const { post } = Astro.props;
const { Content } = await post.render();
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>