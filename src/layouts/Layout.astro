---
import '../styles/global.css';
import Navbar from '../components/navbar.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Joan Francesc Mengibar Prats",
  description = "Portfolio y blog personal sobre ciberseguridad, IoT y hardware hacking."
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang} class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700;900&family=Syncopate:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-white">
    
    <slot />
    
    <Navbar />
    
  </body>
</html>