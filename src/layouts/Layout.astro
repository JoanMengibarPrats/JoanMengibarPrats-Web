---
import '../styles/global.css';
import Navbar from '../components/navbar.astro';

// 1. Importamos nuestra herramienta para saber el idioma de la URL
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
}

const { title = "Joan Francesc Mengibar Prats" } = Astro.props;

// 2. Extraemos el idioma actual
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700;900&family=Syncopate:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-white">
    
    <slot />
    
    <Navbar />
    
  </body>
</html>