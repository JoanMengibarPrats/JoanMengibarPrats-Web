---
// src/components/blog/LavaLampBackground.astro
// Este componente es puramente visual y se quedará en la capa más profunda (z-index: 0)
---

<div class="lava-wrapper absolute inset-0 w-full h-full overflow-hidden z-0">
  <div class="lava-container w-full h-full relative">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
  </div>
</div>

<style>
  /* Contenedor principal para evitar que el blur se salga de la sección */
  .lava-wrapper {
    background-color: #000000;
  }

  /* Aquí ocurre la magia del efecto líquido (Gooey effect) */
  .lava-container {
    background-color: #000000;
    filter: blur(20px) contrast(30);
  }

  /* Estilos base de las burbujas blancas */
  .blob {
    position: absolute;
    background-color: #ffffff;
    border-radius: 50%;
  }

  /* Posiciones, tamaños y animaciones individuales para que parezca orgánico */
  .blob-1 {
    width: 250px;
    height: 250px;
    left: 10%;
    bottom: -50px;
    animation: float1 12s infinite alternate ease-in-out;
  }

  .blob-2 {
    width: 350px;
    height: 350px;
    right: 15%;
    top: -100px;
    animation: float2 18s infinite alternate ease-in-out;
  }

  .blob-3 {
    width: 200px;
    height: 200px;
    left: 40%;
    bottom: 20%;
    animation: float3 15s infinite alternate ease-in-out;
  }

  .blob-4 {
    width: 150px;
    height: 150px;
    right: 35%;
    bottom: -50px;
    animation: float4 10s infinite alternate ease-in-out;
  }
  
  .blob-5 {
    width: 400px;
    height: 100px;
    left: 20%;
    bottom: -50px;
    border-radius: 40%;
    animation: float5 20s infinite alternate ease-in-out;
  }

  /* Keyframes: Movimientos fluidos hacia arriba, abajo y a los lados */
  @keyframes float1 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(150px, -400px) scale(1.2); }
  }

  @keyframes float2 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-200px, 300px) scale(0.9); }
  }

  @keyframes float3 {
    0% { transform: translate(0, 0) scale(1.1); }
    100% { transform: translate(100px, -200px) scale(0.8); }
  }

  @keyframes float4 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-100px, -300px) scale(1.3); }
  }
  
  @keyframes float5 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(300px, -150px) scale(1.1); }
  }
</style>