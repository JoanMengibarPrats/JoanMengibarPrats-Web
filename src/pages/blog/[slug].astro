---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. getStaticPaths genera una página por cada archivo Markdown que tengamos
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 2. Extraemos el post correspondiente a la URL actual
const { post } = Astro.props;
// 3. Extraemos el componente Content para renderizar el Markdown a HTML
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | Joan Francesc`}>
  <main class="min-h-screen pt-32 px-6 md:px-12 max-w-4xl mx-auto font-fira">
    
    <div class="mb-8">
      <a href="/blog" class="inline-block text-green-500 hover:text-green-400 hover:bg-green-500/10 px-3 py-1 rounded transition-colors font-mono border border-transparent hover:border-green-500/30">
        $ cd ..
      </a>
    </div>
    
    <article class="border border-zinc-800 bg-zinc-950 p-6 md:p-10 rounded">
      
      <header class="border-b border-zinc-800 pb-6 mb-8">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-200 mb-4 font-syncopate">
          > {post.data.title}
        </h1>
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 text-zinc-500 font-mono text-sm">
          <time datetime={post.data.pubDate.toISOString()}>
            [{post.data.pubDate.toLocaleDateString('es-ES')}]
          </time>
          {post.data.tags && (
            <div class="flex gap-2">
              {post.data.tags.map(tag => (
                 <span class="text-green-500 bg-green-500/10 border border-green-500/20 px-2 py-0.5 rounded text-xs">#{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>
      
      <div class="text-gray-300 leading-relaxed space-y-4">
        <Content />
      </div>
      
    </article>
  </main>
</Layout>