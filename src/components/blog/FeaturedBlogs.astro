---
// src/components/blog/FeaturedBlogs.astro

import { getLangFromUrl, useTranslations } from '../../i18n/utils';
// 1. Importamos el componente Image
import { Image } from 'astro:assets';
// 2. Importamos la imagen local (esto permite que Astro la procese)
import jfImage from '../../../public/images/JF_.webp'; 

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'es' ? '' : `/${lang}`;

const mockBlogs = [
  { 
    title: t('blog.1.title'), 
    category: t('blog.1.category'), 
    description: t('blog.1.desc'),
    url: `${basePath}/blog/paginaweb`,
    image: jfImage 
  }
];
---

<div class="w-full px-6 md:px-12 lg:px-20 flex flex-col justify-center h-full pt-24 md:pt-32 lg:pt-40 pb-16 md:pb-24">
  
  <div id="list-container" class="border-t border-white mix-blend-difference w-full relative">
    
    {mockBlogs.map((blog, index) => (
      <a href={blog.url} class="blog-item group relative block py-10 md:py-16 transition-colors" data-index={index}>
        
        <div class="absolute bottom-0 left-0 w-full h-[1px] bg-white mix-blend-difference"></div>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 relative z-20 mix-blend-difference text-white pointer-events-none">
          <div class="max-w-3xl"> 
            <h3 class="text-4xl md:text-6xl lg:text-7xl font-syncopate font-bold uppercase tracking-tighter transition-all duration-500 lg:group-hover:translate-x-4 lg:group-hover:text-green-500 group-[.is-active]:translate-x-4 group-[.is-active]:text-green-500">
              {blog.title}
            </h3>
            
            <p class="mt-4 text-base md:text-lg font-fira tracking-wide opacity-80 transition-all duration-500 lg:group-hover:translate-x-4 group-[.is-active]:translate-x-4">
              {blog.description}
            </p>

            <p class="mt-4 text-sm font-fira tracking-widest uppercase transition-all duration-500 lg:group-hover:translate-x-4 lg:group-hover:text-green-500 group-[.is-active]:translate-x-4 group-[.is-active]:text-green-500">
              {blog.category}
            </p>
          </div>

          <div class="hidden md:flex items-center justify-center w-16 h-16 rounded-full border border-transparent transition-all duration-300 lg:group-hover:border-green-500 lg:group-hover:bg-green-500 lg:group-hover:text-black shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </div>
      </a>
    ))}

  </div>

  <div class="w-full flex justify-end mt-12 md:mt-20 relative z-20 mix-blend-difference font-fira text-sm md:text-base font-bold text-white uppercase tracking-widest pointer-events-auto">
    <a href={`${basePath}/blog`} class="relative group interactable hover:text-green-400 transition-colors flex items-center">
      <span class="opacity-0 lg:group-hover:opacity-100 transition-opacity text-green-500 mr-1">></span>
      {t('blog.viewAll')}
    </a>
  </div>

</div>

<div 
  id="global-hover-image" 
  class="hidden md:block pointer-events-none fixed top-0 left-0 z-[100] opacity-0 scale-90 transition-all duration-500 ease-out overflow-hidden shadow-2xl w-[45vw] md:w-[35vw] xl:w-[28vw]"
  style={`aspect-ratio: ${jfImage.width} / ${jfImage.height};`}
>
   {mockBlogs.map((blog, index) => (
      // 4. Cambiamos <img> por <Image />
      <Image 
        src={blog.image} 
        alt={blog.title} 
        data-image-index={index} 
        width={800}
        class="absolute top-0 left-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 ease-in-out" 
      />
   ))}
</div>

<script>
  import gsap from "gsap";

  const listContainer = document.getElementById('list-container');
  const globalContainer = document.getElementById('global-hover-image');
  const globalImages = globalContainer?.querySelectorAll('img');
  const blogItems = document.querySelectorAll('.blog-item');
  const hasHover = window.matchMedia("(hover: hover)").matches;

  if (listContainer && blogItems.length > 0) {
    
    if (hasHover && globalContainer && globalImages) {
      // --- LÓGICA PARA ORDENADORES (GSAP + Hover) ---
      let imageWidth = 0;
      let imageHeight = 0;

      listContainer.addEventListener('mouseenter', () => {
        globalContainer.classList.remove('opacity-0', 'scale-90');
        globalContainer.classList.add('opacity-100', 'scale-100');
        imageWidth = globalContainer.offsetWidth;
        imageHeight = globalContainer.offsetHeight;
      });

      listContainer.addEventListener('mouseleave', () => {
        globalContainer.classList.remove('opacity-100', 'scale-100');
        globalContainer.classList.add('opacity-0', 'scale-90');
      });

      listContainer.addEventListener('mousemove', (e: MouseEvent) => {
        const targetX = e.clientX - (imageWidth / 2);
        const targetY = e.clientY - (imageHeight / 2);

        gsap.to(globalContainer, {
          x: targetX,
          y: targetY,
          duration: 0.6,
          ease: "power2.out",
          overwrite: "auto"
        });
      });

      blogItems.forEach((item) => {
        item.addEventListener('mouseenter', () => {
          const activeIndex = item.getAttribute('data-index');
          
          globalImages.forEach((img) => {
            if (img.getAttribute('data-image-index') === activeIndex) {
              img.classList.remove('opacity-0');
              img.classList.add('opacity-100'); 
            } else {
              img.classList.remove('opacity-100');
              img.classList.add('opacity-0');   
            }
          });
        });
      });

    } else {
      // --- LÓGICA PARA MÓVILES (Efecto "Lava" con Scroll) ---
      
      // Configuramos la zona de "Lava": un margen negativo superior e inferior del 40%.
      // Esto deja solo una franja del 20% en el centro de la pantalla.
      const observerOptions = {
        root: null,
        rootMargin: '-40% 0px -40% 0px',
        threshold: 0
      };

      const lavaObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Cuando entra en la zona de lava, le añadimos la clase
            entry.target.classList.add('is-active');
          } else {
            // Cuando sale, se la quitamos
            entry.target.classList.remove('is-active');
          }
        });
      }, observerOptions);

      blogItems.forEach((item) => {
        lavaObserver.observe(item);
      });
    }
  }
</script>