---
// src/components/game/SamoyedGame.astro

import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const idleSpriteUrl = "/images/samoyed-idle-front.png"; 
const talkSpriteUrl = "/images/samoyed-talk.png"; 
const treatSpriteUrl = "/images/samoyed-treat.png"; 
---

<section id="dog-game" class="w-full min-h-screen bg-black relative flex flex-col items-center justify-center overflow-hidden border-t border-zinc-900 pb-12 md:pb-0">
  
  {/* CAPA 1: TEXTO (TÍTULO) */}
  <div class="w-full absolute inset-0 pointer-events-none z-20">
    <div class="px-6 md:px-0 absolute md:left-12 lg:left-24 top-8 sm:top-16 md:top-32 lg:top-40 pointer-events-auto">
      <div class="interactable flex flex-col items-start">
        <h2 class="text-white font-syncopate font-bold text-5xl md:text-7xl lg:text-[7rem] uppercase tracking-tighter mb-4 lg:mb-6 whitespace-normal xl:whitespace-nowrap">
          {t('maya.title.1')} <span class="text-green-500">MAYA</span>
        </h2>
        <p id="maya-description" class="font-fira text-sm md:text-base text-gray-300 leading-relaxed tracking-wider max-w-sm md:max-w-lg transition-opacity duration-300 opacity-100">
          {t('maya.desc')}
        </p>
      </div>
    </div>
  </div>

  {/* CAPA 2: BOTONES */}
  <div class="absolute bottom-12 right-6 md:bottom-20 md:right-12 lg:right-24 z-30 flex flex-col gap-4 pointer-events-auto items-end">

    <div 
      id="maya-dialog-data"
      data-d1={t('maya.dialog.1')}
      data-d2={t('maya.dialog.2')}
      data-d3={t('maya.dialog.3')}
      data-d4={t('maya.dialog.4')}
      data-d5={t('maya.dialog.5')}
    >
      <button id="btn-hablar" class="btn-game border border-zinc-700 px-6 py-3 text-zinc-500 hover:text-green-400 hover:border-green-400 hover:bg-green-500/10 transition-all interactable text-right w-fit font-syncopate text-xs md:text-sm uppercase tracking-widest">
        {t('maya.btn.talk')}
      </button>
    </div>

    <div
      id="maya-treat-data"
      data-t1={t('maya.treat.1')}
      data-t2={t('maya.treat.2')}
      data-t3={t('maya.treat.3')}
      data-t4={t('maya.treat.4')}
      data-t5={t('maya.treat.5')}
      data-t6={t('maya.treat.6')}
    >
      <button id="btn-treat" class="btn-game border border-zinc-700 px-6 py-3 text-zinc-500 hover:text-green-400 hover:border-green-400 hover:bg-green-500/10 transition-all interactable text-right w-fit font-syncopate text-xs md:text-sm uppercase tracking-widest">
        {t('maya.btn.treat')}
      </button>
    </div>
  </div>

  {/* CAPA 4: DIÁLOGO FLOTANTE - SUBIDO A TOP-[20%] EN MÓVILES */}
  <div id="dialogue-box" class="absolute top-[25%] md:top-[30%] left-1/2 -translate-x-1/2 z-40 text-center pointer-events-none opacity-0 transition-opacity duration-300 w-[90%] md:w-full">
    <p id="dialogue-text" class="font-syncopate text-xl sm:text-2xl md:text-4xl text-white font-bold tracking-widest drop-shadow-[0_5px_5px_rgba(0,0,0,0.8)] transition-all duration-200">
    </p>
  </div>

  {/* CAPA 3: MAYA */}
  <div class="absolute bottom-0 z-10 w-full flex justify-center items-end pointer-events-none">
    <div id="maya-anim-container" class="relative w-[75vw] md:w-[45vh] aspect-[255/403] overflow-hidden"> 
      <img 
        id="maya-idle"
        src={idleSpriteUrl} 
        alt="Maya" 
        class="samoyed-idle absolute left-0 h-[84.4%] bottom-[16%] max-w-none opacity-100 transition-opacity duration-0"
      />
      
      <img 
        id="maya-talk"
        src={talkSpriteUrl} 
        alt="Maya Hablando" 
        class="samoyed-talk absolute left-0 h-[84.4%] bottom-[16%] max-w-none opacity-0 transition-opacity duration-0"
      />
      
      <div 
        id="maya-treat" 
        class="samoyed-treat absolute left-0 bottom-0 w-full h-full opacity-0 transition-opacity duration-0"
        style={`background-image: url(${treatSpriteUrl});`}
      ></div>
    </div>
  </div>

</section>

<style>
  .samoyed-idle {
    image-rendering: pixelated; 
    width: 2000%; 
    animation: play-idle 3.3s steps(20) infinite;
  }
  @keyframes play-idle {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .samoyed-talk {
    image-rendering: pixelated; 
    width: 6600%; 
    animation: play-talk 10s steps(66) forwards;
    animation-play-state: paused;
  }
  
  .samoyed-talk.playing {
    animation-play-state: running;
  }

  @keyframes play-talk {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .samoyed-treat {
    image-rendering: pixelated;
    background-repeat: no-repeat;
    background-size: 1400% 900%; 
    background-position: 0% 0%;
  }

  .btn-game:active {
    transform: translateX(-4px);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnHablar = document.getElementById('btn-hablar');
    const mayaIdle = document.getElementById('maya-idle') as HTMLImageElement;
    const mayaTalk = document.getElementById('maya-talk') as HTMLImageElement;
    
    const btnTreat = document.getElementById('btn-treat');
    const mayaTreat = document.getElementById('maya-treat') as HTMLDivElement;
    
    const dialogueBox = document.getElementById('dialogue-box');
    const dialogueText = document.getElementById('dialogue-text');
    const dialogData = document.getElementById('maya-dialog-data');
    const treatData = document.getElementById('maya-treat-data');
    
    const mayaDescription = document.getElementById('maya-description');

    let isAnimating = false;

    const imgTalk = new Image();
    imgTalk.src = "/images/samoyed-talk.png";
    
    const TREAT_COLS = 14;
    const TREAT_ROWS = 9;
    const TREAT_TOTAL_FRAMES = 116;
    
    const ANIM_FPS = 6; 
    const FRAME_DURATION_MS = 1000 / ANIM_FPS;

    function hideAllSprites() {
        if (mayaIdle) mayaIdle.classList.replace('opacity-100', 'opacity-0');
        if (mayaTalk) mayaTalk.classList.replace('opacity-100', 'opacity-0');
        if (mayaTreat) mayaTreat.classList.replace('opacity-100', 'opacity-0');
        if (mayaTalk) mayaTalk.classList.remove('playing');
    }

    function toggleMobileDescription(show: boolean) {
        if (!mayaDescription) return;
        if (window.innerWidth < 768) {
            if (show) {
                mayaDescription.classList.replace('opacity-0', 'opacity-100');
            } else {
                mayaDescription.classList.replace('opacity-100', 'opacity-0');
            }
        }
    }

    btnHablar?.addEventListener('click', () => {
      if (isAnimating) return; 
      isAnimating = true;
      
      toggleMobileDescription(false);

      if (dialogueText && dialogueBox && dialogData) {
        dialogueText.className = "font-syncopate text-xl sm:text-2xl md:text-4xl text-white font-bold tracking-widest drop-shadow-[0_5px_5px_rgba(0,0,0,0.8)] transition-all duration-200";
        
        setTimeout(() => {
          dialogueText.innerText = dialogData.dataset.d1 || "";
          dialogueBox.classList.remove('opacity-0');
          dialogueBox.classList.add('opacity-100');
        }, 700); 

        setTimeout(() => { if (dialogueText) dialogueText.innerText = dialogData.dataset.d2 || ""; }, 2500);
        setTimeout(() => { if (dialogueText) dialogueText.innerText = dialogData.dataset.d3 || ""; }, 5500);
        setTimeout(() => { if (dialogueText) dialogueText.innerText = dialogData.dataset.d4 || ""; }, 6900);
        
        setTimeout(() => { 
          if (dialogueText) {
            dialogueText.innerText = dialogData.dataset.d5 || "";
            dialogueText.classList.remove('text-white');
            dialogueText.classList.add('text-green-500', 'scale-125');
          }
        }, 7600);
      }

      mayaTalk.style.animation = 'none';
      void mayaTalk.offsetWidth; 
      mayaTalk.style.animation = '';

      hideAllSprites();
      mayaTalk.classList.replace('opacity-0', 'opacity-100');
      mayaTalk.classList.add('playing');

      mayaTalk.addEventListener('animationend', () => {
        hideAllSprites();
        mayaIdle.classList.replace('opacity-0', 'opacity-100');
        
        if (dialogueBox) {
          dialogueBox.classList.remove('opacity-100');
          dialogueBox.classList.add('opacity-0');
        }
        
        toggleMobileDescription(true);
        isAnimating = false;
      }, { once: true }); 
    });

    btnTreat?.addEventListener('click', () => {
        if (isAnimating) return; 
        isAnimating = true;

        toggleMobileDescription(false);

        if (dialogueText && dialogueBox && treatData) {
            dialogueText.className = "font-syncopate text-xl sm:text-2xl md:text-4xl text-white font-bold tracking-widest drop-shadow-[0_5px_5px_rgba(0,0,0,0.8)] transition-all duration-200";
            
            setTimeout(() => {
                dialogueText.innerText = treatData.dataset.t1 || "¿Quiéres un premio?";
                dialogueBox.classList.remove('opacity-0');
                dialogueBox.classList.add('opacity-100');
            }, 1000);
            
            setTimeout(() => { 
                if (dialogueText) {
                    dialogueText.innerText = treatData.dataset.t2 || "Guau";
                    dialogueText.classList.remove('text-white');
                    dialogueText.classList.add('text-green-500', 'scale-125');
                }
            }, 4500);

            setTimeout(() => { 
                if (dialogueText) {
                    dialogueText.innerText = treatData.dataset.t3 || "sienta";
                    dialogueText.classList.remove('text-green-500', 'scale-125'); 
                    dialogueText.classList.add('text-white'); 
                }
            }, 6500);
            
            setTimeout(() => { if (dialogueText) dialogueText.innerText = treatData.dataset.t4 || "tumba"; }, 8000);
            setTimeout(() => { if (dialogueText) dialogueText.innerText = treatData.dataset.t5 || "vuelta"; }, 11500);
            setTimeout(() => { 
                if (dialogueText) {
                    dialogueText.innerText = treatData.dataset.t6 || "muy bién";
                }
            }, 17000);
        }

        let currentFrame = 0;
        let treatIntervalId: number;

        hideAllSprites();
        mayaTreat.classList.replace('opacity-0', 'opacity-100');
        mayaTreat.style.backgroundPosition = '0% 0%';

        treatIntervalId = window.setInterval(() => {
            currentFrame++;

            if (currentFrame >= TREAT_TOTAL_FRAMES) {
                clearInterval(treatIntervalId);
                endTreatAnimation();
                return;
            }

            const colIndex = currentFrame % TREAT_COLS;
            const rowIndex = Math.floor(currentFrame / TREAT_COLS);

            const percentageX = (colIndex / (TREAT_COLS - 1)) * 100;
            const percentageY = (rowIndex / (TREAT_ROWS - 1)) * 100;

            mayaTreat.style.backgroundPosition = `${percentageX.toFixed(3)}% ${percentageY.toFixed(3)}%`;

        }, FRAME_DURATION_MS);

        function endTreatAnimation() {
            hideAllSprites();
            mayaIdle.classList.replace('opacity-0', 'opacity-100');
            
            if (dialogueBox) {
                dialogueBox.classList.remove('opacity-100');
                dialogueBox.classList.add('opacity-0');
            }
            
            toggleMobileDescription(true);
            isAnimating = false;
        }
    });

  });
</script>