---
// 1. IMPORTANTE: Añadimos 'render' a la importación
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // 2. Cambiamos 'post.slug' por 'post.id'
  const spanishPosts = posts.filter(post => post.id.startsWith('es/'));
  
  return spanishPosts.map(post => {
    // 3. Cambiamos 'post.slug' por 'post.id' aquí también
    const cleanSlug = post.id.replace('es/', '');
    
    return {
      params: { slug: cleanSlug }, 
      props: { post },             
    };
  });
}

const { post } = Astro.props;

// 4. Usamos la nueva función render() pasándole el post como argumento
const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>