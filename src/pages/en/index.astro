---
// src/pages/en/index.astro
import Layout from '../../layouts/Layout.astro';
import NameLayer from '../../components/home/NameLayer.astro';
import CodeMaskLayer from '../../components/home/CodeMaskLayer.astro';
import About from '../../components/about/About.astro';
import LavaLampBackground from '../../components/blog/LavaLampBackground.astro';
import FeaturedBlogs from '../../components/blog/FeaturedBlogs.astro';
import Samoyedo from '../../components/SamoyedGame.astro';
---

<Layout title="Joan Francesc Mengibar Prats - English">
  <section id="home" class="relative w-screen h-screen overflow-hidden">
    <NameLayer />
    <CodeMaskLayer />
  </section>

  <section id="blog" class="w-full min-h-screen bg-black flex flex-col items-center justify-center py-24 px-6 md:px-12 font-fira relative">
    <LavaLampBackground />
    <FeaturedBlogs />
  </section>

  <About />

  <Samoyedo />

  <script>
    import gsap from "gsap";

    const homeSection = document.getElementById('home');
    const maskLayer = document.getElementById('mask-layer');
    
    let isVisible = false;
    let isHoveringElement = false;

    const getBaseRadius = () => {
      const w = window.innerWidth;
      const h = window.innerHeight;

      if (w > h && h < 600) return 120;
      if (w < 768) return 130;
      return 220;
    };

    const interactables = document.querySelectorAll('.interactable');
    interactables.forEach((el) => {
      el.addEventListener('mouseenter', () => { isHoveringElement = true; });
      el.addEventListener('mouseleave', () => { isHoveringElement = false; });
    });

    const handleMove = (x: number, y: number) => {
      if (!isVisible) {
        if (maskLayer) {
          gsap.set(maskLayer, { clipPath: `circle(0px at ${x}px ${y}px)` });
          gsap.to(maskLayer, { 
            clipPath: `circle(${getBaseRadius()}px at ${x}px ${y}px)`, 
            duration: 0.8, 
            ease: "power3.out" 
          });
        }
        isVisible = true;
      } else {
        const currentRadius = isHoveringElement ? 0 : getBaseRadius();
        if (maskLayer) {
          gsap.to(maskLayer, {
            clipPath: `circle(${currentRadius}px at ${x}px ${y}px)`,
            duration: 0.4, 
            ease: "power2.out"
          });
        }
      }
    };

    const handleLeave = (x: number, y: number) => {
      isVisible = false;
      if (maskLayer) {
        gsap.to(maskLayer, { 
          clipPath: `circle(0px at ${x}px ${y}px)`, 
          duration: 0.6, 
          ease: "power3.out" 
        });
      }
    };

    if (homeSection) {
      homeSection.addEventListener('mousemove', (e) => {
        const rect = homeSection.getBoundingClientRect();
        handleMove(e.clientX - rect.left, e.clientY - rect.top);
      });

      homeSection.addEventListener('mouseleave', (e) => {
        const rect = homeSection.getBoundingClientRect();
        handleLeave(e.clientX - rect.left, e.clientY - rect.top);
      });

      homeSection.addEventListener('touchstart', (e) => {
        const touch = e.touches[0];
        const rect = homeSection.getBoundingClientRect();
        handleMove(touch.clientX - rect.left, touch.clientY - rect.top);
      }, { passive: true });

      homeSection.addEventListener('touchmove', (e) => {
        const touch = e.touches[0];
        const rect = homeSection.getBoundingClientRect();
        handleMove(touch.clientX - rect.left, touch.clientY - rect.top);
      }, { passive: true });

      homeSection.addEventListener('touchend', (e) => {
        if (e.changedTouches && e.changedTouches.length > 0) {
          const touch = e.changedTouches[0];
          const rect = homeSection.getBoundingClientRect();
          handleLeave(touch.clientX - rect.left, touch.clientY - rect.top);
        }
      });
    }
  </script>
</Layout>